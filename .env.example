# =============================================================
# Cotizador Multi-Industria — variables de entorno
# Copiar a .env (nunca commitear .env real) y completar valores.
# =============================================================

# URL base pública del sitio. Hoy fija a producción; migrable sin tocar
# código porque todos los links (wa.me, PDFs, etc.) se arman desde acá.
BASE_URL=https://cotizador.sentidocomun.click

# --- Supabase self-hosted ---------------------------------------------
# URL pública de la instancia (Kong / API gateway de Supabase).
NEXT_PUBLIC_SUPABASE_URL=
# Anon key: pública, va al bundle del cliente. Solo sirve para Auth;
# el acceso a datos siempre pasa por RLS o por rutas con service role.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key: SOLO server-side. Nunca debe llegar al cliente.
SUPABASE_SERVICE_ROLE_KEY=

# --- Claude API (textos de presupuesto, Fase 1) -------------------------
# Si falta, el sistema NO se rompe: usa un texto por template determinístico.
ANTHROPIC_API_KEY=

# --- SMTP (Fase 2+, emails transaccionales) -----------------------------
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=
